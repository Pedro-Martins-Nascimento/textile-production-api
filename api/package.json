{
  "name": "textile-production-api-server",
  "version": "1.0.0",
  "description": "API RESTful para registro de produção de teares circulares",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "coverage": "jest --coverage --runInBand"
  },
  "jest": {
    "coverageDirectory": "../coverage",
    "coverageReporters": ["html", "text-summary"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^17.4.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "license": "MIT"
}
